{
  "name": "agentic-service",
  "version": "0.1.0",
  "type": "module",
  "description": "Local-first AI service with hardware detection and model optimization",
  "main": "src/index.js",
  "bin": {
    "agentic-service": "bin/agentic-service.js"
  },
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "start": "node bin/agentic-service.js",
    "dev": "node bin/agentic-service.js --skip-setup",
    "build": "cd src/ui/admin && npm install && npm run build",
    "tunnel": "node src/tunnel.js"
  },
  "keywords": [
    "ai",
    "llm",
    "ollama",
    "local-first"
  ],
  "author": "",
  "license": "MIT",
  "vitest": {
    "coverage": {
      "thresholds": {
        "statements": 98,
        "lines": 98,
        "branches": 98,
        "functions": 98
      }
    }
  },
  "devDependencies": {
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "imports": {
    "#agentic-embed": "./src/runtime/adapters/embed.js",
    "#agentic-sense": "./src/runtime/adapters/sense.js"
  },
  "dependencies": {
    "agentic-embed": "*",
    "agentic-voice": "*",
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "open": "^10.2.0",
    "ora": "^9.3.0",
    "ws": "^8.20.0"
  }
}
